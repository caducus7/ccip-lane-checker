# RPC endpoints (Alchemy, Infura, or public)
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Deployer wallet — use ONE of:
#   Keystore (recommended): import with `cast wallet import laneDeployer --interactive`
#   Raw key (session only): PRIVATE_KEY=0x...
PRIVATE_KEY=
DEPLOYER=
KEYSTORE_ACCOUNT=laneDeployer

# Block explorer verification (forge --verify; same key works for Etherscan, Arbiscan, Basescan)
ETHERSCAN_API_KEY=

# Per-chain VRF v2.5 subscription IDs (create at vrf.chain.link; set when running DeployAll per chain)
VRF_SUBSCRIPTION_ID=

# Target chain for DeployAll.s.sol / DeployLaneToken.s.sol:
#   sepolia | arbitrum-sepolia | base-sepolia
DEPLOY_CHAIN=sepolia

# CRE Keystone metadata allowlists (required unless CRE_ALLOWLIST_OPTIONAL=true for local)
CRE_WORKFLOW_OWNER=
CRE_WORKFLOW_ID=
# CRE_ALLOWLIST_OPTIONAL=true

# Optional treasury overrides (default to deployer)
PLATFORM_TREASURY=
GAS_RESERVE=

# Phase 2 peer wiring (see docs/DEPLOY_TESTNET.md)
# REMOTE_EXECUTOR_SEPOLIA=
# REMOTE_EXECUTOR_ARBITRUM_SEPOLIA=
# REMOTE_EXECUTOR_BASE_SEPOLIA=
# REMOTE_LANE_TOKEN_SEPOLIA=
# REMOTE_LANE_TOKEN_ARBITRUM_SEPOLIA=
# REMOTE_LANE_TOKEN_BASE_SEPOLIA=
