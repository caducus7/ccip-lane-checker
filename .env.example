# =============================================================================
# CCIP Lane Checker — environment reference (copy to .env; never commit secrets)
# =============================================================================

# --- RPC endpoints (contracts / forge / fork tests) ---
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org

# --- Contract deploy (contracts/script/DeployAll.s.sol) ---
# Keystore (recommended): cast wallet import laneDeployer --interactive
PRIVATE_KEY=
DEPLOYER=
KEYSTORE_ACCOUNT=laneDeployer
DEPLOY_CHAIN=sepolia
VRF_SUBSCRIPTION_ID=
PLATFORM_TREASURY=
GAS_RESERVE=

# CRE Keystone metadata allowlists (required unless CRE_ALLOWLIST_OPTIONAL=true)
CRE_WORKFLOW_OWNER=
CRE_WORKFLOW_ID=
# CRE_ALLOWLIST_OPTIONAL=true

# Block explorer verification (forge --verify on all three testnets)
ETHERSCAN_API_KEY=

# Phase 2 peer wiring (optional; see docs/DEPLOY_TESTNET.md)
# REMOTE_EXECUTOR_SEPOLIA=
# REMOTE_EXECUTOR_ARBITRUM_SEPOLIA=
# REMOTE_EXECUTOR_BASE_SEPOLIA=
# REMOTE_LANE_TOKEN_SEPOLIA=
# REMOTE_LANE_TOKEN_ARBITRUM_SEPOLIA=
# REMOTE_LANE_TOKEN_BASE_SEPOLIA=

# --- Frontend (frontend/.env.local) ---
# NEXT_PUBLIC_* values are bundled into the browser (addresses/RPCs are public by design).
# Keep secrets out of NEXT_PUBLIC_ (use LANE_BENCHMARK_AUTH_TOKEN, PRIVATE_KEY, etc.).
NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Ethereum Sepolia contract overrides (fill after deploy; defaults from testnet.json)
NEXT_PUBLIC_SEPOLIA_LANE_TOKEN=
NEXT_PUBLIC_SEPOLIA_LANE_CONTROLLER=
NEXT_PUBLIC_SEPOLIA_LANE_EXECUTOR=
NEXT_PUBLIC_SEPOLIA_LINK=0x779877A7B0D9E8603169DdbD7836e478b4624789

# Arbitrum Sepolia contract overrides
NEXT_PUBLIC_ARBITRUM_SEPOLIA_LANE_TOKEN=
NEXT_PUBLIC_ARBITRUM_SEPOLIA_LANE_CONTROLLER=
NEXT_PUBLIC_ARBITRUM_SEPOLIA_LANE_EXECUTOR=
NEXT_PUBLIC_ARBITRUM_SEPOLIA_LINK=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E

# Base Sepolia contract overrides
NEXT_PUBLIC_BASE_SEPOLIA_LANE_TOKEN=
NEXT_PUBLIC_BASE_SEPOLIA_LANE_CONTROLLER=
NEXT_PUBLIC_BASE_SEPOLIA_LANE_EXECUTOR=
NEXT_PUBLIC_BASE_SEPOLIA_LINK=0xE4aB69C077896252FAFBD49EFD26B5D171A32410

# WalletConnect (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Lane benchmark API auth (frontend /api/lanes POST; required in production)
LANE_BENCHMARK_AUTH_TOKEN=

# --- CRE workflows (cre/lane-checker-cre) ---
# Set CRE_SIMULATE=1 to run local workflow simulate via scripts/cre-simulate-check.sh
CRE_SIMULATE=0
